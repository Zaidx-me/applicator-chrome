{
  "manifest_version": 3,
  "name": "Applicator",
  "version": "1.0.0",
  "description": "Generate cover letters for job applications using AI",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "host_permissions": ["https://*.linkedin.com/*", "https://*.indeed.com/*", "https://*.rozee.pk/*", "https://web.whatsapp.com/*", "https://mail.google.com/*", "https://integrate.api.nvidia.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Applicator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content-linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.indeed.com/*"],
      "js": ["content-indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content-whatsapp.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.rozee.pk/*"],
      "js": ["content-rozee.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
